{
  "name": "codex-subagent-kit-workspace",
  "private": true,
  "packageManager": "npm@11.4.1",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build:ts": "npm run build --workspace codex-subagent-kit",
    "pack:ts": "npm pack --workspace codex-subagent-kit --dry-run",
    "test:ts": "npm run test --workspace codex-subagent-kit",
    "typecheck:ts": "npm run typecheck --workspace codex-subagent-kit"
  }
}
